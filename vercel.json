{
  "rewrites": [
    { "source": "/api/approve-sponsor", "destination": "/api/sponsor-request?action=approve" },
    { "source": "/api/get-sponsor-request", "destination": "/api/sponsor-request?action=get" },
    { "source": "/api/list-sponsor-requests", "destination": "/api/sponsor-request?action=list" },
    { "source": "/api/upload-sponsor-assets", "destination": "/api/sponsor-request?action=upload" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" }
      ]
    }
  ]
}
